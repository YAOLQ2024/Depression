# ============================================
# 抑郁症评估系统 - 环境配置文件模板
# ============================================
# 复制此文件为 .env 并填入您的实际配置值

# ============================================
# 硅基流动 API 配置
# ============================================
# API 密钥（必填）
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# API 地址（可选，默认使用硅基流动）
SILICONFLOW_API_URL=https://api.siliconflow.cn/v1/chat/completions

# 模型名称（可选，默认使用 deepseek-chat）
# 可选值：deepseek-chat, Qwen/Qwen2.5-7B-Instruct 等
SILICONFLOW_MODEL=deepseek-chat

# ============================================
# 本地 LLM 低显存启动配置（vLLM）
# ============================================
# 默认改为更保守的低显存配置，适合单用户本地演示
# 如果仍然超显存，可继续降为：
# LLM_MAX_MODEL_LEN=1024
# LLM_GPU_MEMORY_UTILIZATION=0.50
# LLM_MAX_NUM_SEQS=1
LLM_DTYPE=auto
LLM_MAX_MODEL_LEN=2048
LLM_GPU_MEMORY_UTILIZATION=0.60
LLM_MAX_NUM_SEQS=2

# ============================================
# Tavily 联网搜索 API 配置
# ============================================
# Tavily API 密钥（可选，用于联网搜索功能）
# 如果不需要联网搜索功能，可以留空
TAVILY_API_KEY=your_tavily_api_key_here

# ============================================
# EEG 采集配置
# ============================================
# 可选值：serial / lsl
# serial: 服务器直接连接脑电设备
# lsl:    Windows 采集端通过局域网推送 LSL，Linux 服务器负责接收和展示
EEG_SOURCE=lsl

# 串口模式配置
EEG_SERIAL_PORT=/dev/ttyUSB0
EEG_BAUD_RATE=230400

# LSL 模式配置
# 建议与 Windows 采集端 StreamInfo(name=...) 保持一致
EEG_LSL_STREAM_NAME=EEG_Data
EEG_LSL_STREAM_TYPE=EEG

# 0-based 通道映射，前端当前只画 3 个通道
# 例如你的 LSL 流有 8 个通道，想显示第 1/2/3 个通道，就填 0,1,2
EEG_LSL_CHANNEL_MAP=0,1,2

# 如果 Windows 端额外推送了特征流（格式为 [theta,alpha,beta] * 3），可以打开下面两项
# EEG_LSL_FEATURE_STREAM_NAME=EEG_Features
# EEG_LSL_FEATURE_STREAM_TYPE=EEG_Features

# LSL 拉流超时（秒）
EEG_LSL_RESOLVE_TIMEOUT=2
EEG_LSL_PULL_TIMEOUT=0.2

# 如果局域网屏蔽了 LSL 组播发现，可以显式指定参与联调的机器 IP
# 两端都建议写成同一个列表，例如：10.102.5.24,10.102.5.33
# EEG_LSL_KNOWN_PEERS=10.102.5.24,10.102.5.33

# 建议 Windows 发送端和 Linux 接收端都使用同一个 SessionID
# EEG_LSL_SESSION_ID=depression-eeg

# 发现链路不稳定时，通常建议把作用域收窄到 machine，并禁用 IPv6
# EEG_LSL_RESOLVE_SCOPE=machine
# EEG_LSL_DISABLE_IPV6=1

# 也可以直接指定现成的 lsl_api.cfg 路径
# EEG_LSL_CONFIG_PATH=/path/to/lsl_api.cfg
